<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#0f0f0f">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Clipboard Sync"
            android:textColor="#eee"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL del servidor"
            android:textColor="#888"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/url_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="http://192.168.1.100:3737"
            android:textColor="#eee"
            android:textColorHint="#555"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="14dp"
            android:inputType="textUri"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

        <Button
            android:id="@+id/scan_btn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Escanear QR"
            android:textAllCaps="false"
            android:backgroundTint="#44ff88"
            android:textColor="#000"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/save_btn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Guardar"
            android:textAllCaps="false"
            android:backgroundTint="#333"
            android:textColor="#eee"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/test_btn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Probar conexión"
            android:textAllCaps="false"
            android:backgroundTint="#4488ff"
            android:textColor="#fff"
            android:layout_marginStart="6dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222"
            android:layout_marginVertical="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sincronización automática"
            android:textColor="#eee"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Al copiar texto se envía automáticamente a la PC"
                android:textColor="#aaa"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/enable_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#00ff88"
                android:trackTint="#333" />

        </LinearLayout>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Servicio inactivo"
            android:textColor="#666"
            android:textSize="13sp"
            android:layout_marginTop="16dp"
            android:gravity="center" />

        <Button
            android:id="@+id/sync_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Enviar texto de prueba"
            android:textAllCaps="false"
            android:backgroundTint="#44ff88"
            android:textColor="#000"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paso 1: Activá el servicio de accesibilidad en Ajustes > Accesibilidad > Clipboard Sync"
            android:textColor="#555"
            android:textSize="12sp"
            android:layout_marginTop="24dp"
            android:lineSpacingExtra="3dp" />

        <Button
            android:id="@+id/battery_btn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Paso 2: Optimización de batería - Sin restricción"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:backgroundTint="#ff4444"
            android:textColor="#fff"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paso 3 (Samsung): Ajustes > Cuidado batería > Apps en reposo profundo > Sacar Clipboard Sync de la lista"
            android:textColor="#555"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

</ScrollView>
